#!/bin/bash

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "${SOURCE}" ]; do
  SOURCE_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
  TARGET="$(readlink "${SOURCE}")"
  if [[ "${TARGET}" != /* ]]; then
    SOURCE="${SOURCE_DIR}/${TARGET}"
  else
    SOURCE="${TARGET}"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "${SOURCE}")" && pwd)"
exec "${SCRIPT_DIR}/../codexfast.sh" "$@"
