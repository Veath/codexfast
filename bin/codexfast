function stripTomlComment(line) {
    let quote = null;
    let escaped = false;
    for (let index = 0; index < line.length; index += 1) {
        const char = line[index];
        if (escaped) {
            escaped = false;
            continue;
        }
        if (char === "\\" && quote !== null) {
            escaped = true;
            continue;
        }
        if ((char === '"' || char === "'") && (quote === null || quote === char)) {
            quote = quote === null ? char : null;
            continue;
        }
        if (char === "#" && quote === null) {
            return line.slice(0, index);
        }
    }
    return line;
}
function isAutomaticUpdatesDisabledInConfigContent(content) {
    let currentTable = "";
    let legacyValue = null;
    let desktopValue = null;
    for (const rawLine of content.split(/\r?\n/u)) {
        const line = stripTomlComment(rawLine).trim();
        if (!line) {
            continue;
        }
        const tableMatch = /^\[([^\[\]]+)\]$/u.exec(line);
        if (tableMatch) {
            currentTable = tableMatch[1].trim();
            continue;
        }
        const match = /^disableAutomaticUpdates\s*=\s*(true|false)\s*$/u.exec(line);
        if (match) {
            const value = match[1] === "true";
            if (currentTable === "desktop") {
                desktopValue = value;
            }
            else if (currentTable === "" && legacyValue === null) {
                legacyValue = value;
            }
        }
    }
    return desktopValue ?? legacyValue ?? false;
}
function resolveCodexHome(env = process.env) {
    const configuredHome = env.CODEX_HOME?.trim();
    if (configuredHome) {
        return configuredHome;
    }
    const home = env.HOME?.trim() || (0, node_os_1.homedir)();
    return home ? (0, node_path_1.join)(home, ".codex") : null;
}
function isAutomaticUpdatesDisabledInConfig(env = process.env) {
    const codexHome = resolveCodexHome(env);
    if (!codexHome) {
        return false;
    }
    const configPath = (0, node_path_1.join)(codexHome, "config.toml");
    if (!(0, node_fs_1.existsSync)(configPath)) {
        return false;
    }
    try {
        return isAutomaticUpdatesDisabledInConfigContent((0, node_fs_2.readFileSync)(configPath, "utf8"));
    }
    catch {
        return false;
    }
}
function patchMainProcessAutomaticUpdateSource(source) {
    let patchedSource = source.replace(MAIN_PROCESS_AUTOMATIC_UPDATE_SIGNATURE, (_match, intervalVar, readIntervalVar) => `let ${intervalVar}=${readIntervalVar}(),${MAIN_PROCESS_AUTOMATIC_UPDATE_READER},codexfastAutomaticUpdatesDisabled=${MAIN_PROCESS_AUTOMATIC_UPDATE_DISABLED_CHECK},codexfastAutomaticUpdateCheck=()=>{if(codexfastAutomaticUpdatesDisabled())return;d()};${intervalVar}>0&&setInterval(codexfastAutomaticUpdateCheck,${intervalVar}).unref(),codexfastAutomaticUpdateCheck()`);
    if (patchedSource === source) {
        patchedSource = source.replace(MAIN_PROCESS_AUTOMATIC_UPDATE_CALLBACK_SIGNATURE, (_match, intervalVar, readIntervalVar, callbackVar) => `let ${intervalVar}=${readIntervalVar}(),${MAIN_PROCESS_AUTOMATIC_UPDATE_READER},codexfastAutomaticUpdatesDisabled=${MAIN_PROCESS_AUTOMATIC_UPDATE_DISABLED_CHECK},codexfastAutomaticUpdateCheck=()=>{if(codexfastAutomaticUpdatesDisabled())return;${callbackVar}()};${intervalVar}>0&&setInterval(codexfastAutomaticUpdateCheck,${intervalVar}).unref(),codexfastAutomaticUpdateCheck()`);
    }
    if (patchedSource === source) {
        return source;
    }
    let patchedAutomaticDownloadGate = patchedSource.replace(MAIN_PROCESS_AUTOMATIC_DOWNLOAD_GATE_SIGNATURE, (_match, enabledVar, setAutomaticBackgroundDownloadsEnabledCall) => `this.setAutomaticBackgroundDownloadsEnabledForMac=${enabledVar}=>{${setAutomaticBackgroundDownloadsEnabledCall},${enabledVar}&&codexfastAutomaticUpdateCheck()},this.updater=`);
    patchedAutomaticDownloadGate = patchedAutomaticDownloadGate.replace(MAIN_PROCESS_AUTOMATIC_DOWNLOAD_CONDITIONAL_GATE_SIGNATURE, (_match, enabledVar, setAutomaticBackgroundDownloadsEnabledCall, productionAppcastVar, _callbackVar) => `this.setAutomaticBackgroundDownloadsEnabledForMac=${enabledVar}=>{${setAutomaticBackgroundDownloadsEnabledCall},${enabledVar}&&!${productionAppcastVar}&&codexfastAutomaticUpdateCheck()},this.updater=`);
    return patchedAutomaticDownloadGate.replace(MAIN_PROCESS_FORCED_UPDATE_SCHEDULE_SIGNATURE, MAIN_PROCESS_FORCED_UPDATE_SCHEDULE_REPLACEMENT);
}
function patchMainProcessSettingsSchemaSource(source) {
    return source.replace(MAIN_PROCESS_SETTINGS_SCHEMA_SIGNATURE, MAIN_PROCESS_SETTINGS_SCHEMA_REPLACEMENT);
}
