        printLine("CDP frame self-test failed");
        return 1;
    }
    catch (error) {
        if (!asError(error).message.includes("too large")) {
            printLine("CDP frame self-test failed");
            return 1;
        }
    }
    printLine("CDP frame self-test passed");
